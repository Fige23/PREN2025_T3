{
  "version": 7,
  "cmakeMinimumRequired": {
    "major": 3
  },
  "configurePresets": [
    {
    "name": "Debug",
    "displayName": "Debug",
    "generator": "Ninja",
    "binaryDir": "${sourceDir}/cmake-build/${presetName}",
    "toolchainFile": "${sourceDir}/armgcc.cmake",
    "inherits": "Debug-env",
    "cacheVariables": {
    "POSTPROCESS_UTILITY": "$env{POSTPROCESS_UTILITY}",
    "LIBRARY_TYPE": "REDLIB",
    "LANGUAGE": "C",
    "DEBUG_CONSOLE": "SEMIHOST",
    "CMAKE_BUILD_TYPE": "Debug",
    "SdkRootDirPath": "$env{SdkRootDirPath}",
    "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/cmake-build/${presetName}",
    "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/cmake-build/${presetName}",
    "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/cmake-build/${presetName}"
  }
}
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "displayName": "Debug",
      "configurePreset": "Debug"
    }
  ],
  "include": [
    "mcux_include.json"
  ]
}